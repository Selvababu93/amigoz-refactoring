# --- OS & IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Secrets ---
.env
*.env
*.pem
*.key

# --- Python / FastAPI ---
**/__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
# Keep your 'static' folder but ignore the uploaded/processed images
backend/static/processed/*

# --- Flutter (Mobile & Web) ---
# We ignore the local build folders to ensure Docker builds fresh
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
# Specific path to avoid blocking backend folders
client/build/
client/.dart_tool/
android/
ios/

# --- React / Vite (Frontend) ---
# If your portfolio is in a 'frontend' folder:
frontend/node_modules/
# IMPORTANT: Do NOT ignore the final 'dist' folder if you build
# outside Docker and then COPY it in.
# If you build INSIDE Docker, ignore it:
# frontend/dist/

# --- Docker ---
Dockerfile
docker-compose.yml
*.log
*.pid
